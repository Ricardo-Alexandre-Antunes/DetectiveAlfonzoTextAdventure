    </children>
  </item>
  <item nodeId="node-169">
    <command xml:space="preserve">go east</command>
    <result xml:space="preserve">St Miku Crossing&#x000A;St. Miku Crossing, the epitome of modern city living, a sea of people surrounded by cars, shops and buildings as tall as the eye can see, piercing the clouds above like a knife.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
