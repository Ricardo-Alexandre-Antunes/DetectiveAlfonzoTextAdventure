  <item nodeId="node-102">
    <command xml:space="preserve">go inside</command>
    <result xml:space="preserve">I don't really know where Judge Richards's chambers are... perhaps I should look for someone who knows.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
