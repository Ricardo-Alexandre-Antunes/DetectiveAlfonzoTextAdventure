    <command xml:space="preserve">Take old key</command>
    <result xml:space="preserve">A key? I wonder what I could do with this...&#x000A;&#x000A;Taken.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
