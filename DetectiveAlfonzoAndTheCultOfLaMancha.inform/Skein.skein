  <item nodeId="node-459">
    <command xml:space="preserve">showme</command>
    <result xml:space="preserve">Office - room&#x000A;    yourself - person&#x000A;    desk - supporter&#x000A;        doctor's note&#x000A;        old newspaper&#x000A;        tablet&#x000A;    closet - closed container&#x000A;        *pile of paper&#x000A;        *NSFW Magazine&#x000A;    rack - supporter&#x000A;        green hat - hat&#x000A;        red hat - hat&#x000A;        black hat - hat&#x000A;        tiara - hat&#x000A;        trophy&#x000A;* denotes things which are not in scope&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
  </item>
  <item nodeId="node-460">
    <command xml:space="preserve">take tiara</command>
