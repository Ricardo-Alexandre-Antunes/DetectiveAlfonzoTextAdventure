  <item nodeId="node-410">
    <command xml:space="preserve">east</command>
    <result xml:space="preserve">Suspicious Alley&#x000A;The door lead to a narrow, stinking alleyway, isolated from the rest of the city.&#x000A;&#x000A;There's rats all over and spiders crawling on the walls. There is no way to go but forwards, to the darkness.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
