  <item nodeId="node-332">
    <command xml:space="preserve">talk</command>
    <result xml:space="preserve">(to Mike)&#x000A;"I wanted to see the small ducks, but they are under construction..."&#x000A;...&#x000A;"I mean the park, not the ducks!&#x000A;Oh. Ok... I'm just gonna go now...&#x000A;"Oh ok Mr. High-And-Mighty-Normal-Hat-Wearer. Could at least wear something cool like a tiara!"&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
